def fx_sparkle(surf, cx, cy, frame):
    for i in range(8):
        angle = i * 45 + frame * 2
        r = 40 + math.sin(frame * 0.1 + i) * 10
        sx = cx + int(r * math.cos(math.radians(angle)))
        sy = cy + int(r * math.sin(math.radians(angle)))
        sz = 3 + int(math.sin(frame * 0.15 + i) * 2)
        clr = PINK if i % 2 == 0 else YELLOW
        pygame.draw.circle(surf, clr, (sx, sy), max(1, sz))
        for j in range(4):
            pa = j * 90
            px = sx + int(5 * math.cos(math.radians(pa)))
            py = sy + int(5 * math.sin(math.radians(pa)))
            pygame.draw.circle(surf, PINK, (px, py), 2)


def fx_shatter(surf, frame):
    n = min(frame % 60, 30)
    for i in range(12):
        angle = i * 30 + n * 3
        dist = n * 8
        sx = W // 2 + int(dist * math.cos(math.radians(angle)))
        sy = H // 2 + int(dist * math.sin(math.radians(angle)))
        pts = [(sx, sy - 8), (sx + 5, sy), (sx, sy + 8), (sx - 5, sy)]
        aa = max(0, 255 - n * 8)
        col = (255, 255, 255) if aa > 128 else (200, 200, 200)
        pygame.draw.polygon(surf, col, pts, 2)


def fx_debt_vision(surf, text, x, y, frame):
    alpha = int(128 + 127 * math.sin(frame * 0.1))
    s = pygame.Surface((350, 40), pygame.SRCALPHA)
    t = f_debt.render(text, True, (220, 50, 50, min(255, max(0, alpha))))
    s.blit(t, (0, 0))
    surf.blit(s, (x - 175, y))


