def draw_cunam(surf, x, y, pose="standing", facing=1, mouth="flat", eyes="normal", frame=0):
    """Gambar Cunam. x,y = posisi kaki di tanah."""
    bob = math.sin(frame * 0.08) * 2
    y = int(y + bob)
    f = facing
    hr = 20
    sw = 3

    # --- Hitung posisi badan berdasarkan pose ---
    if pose in ("squatting", "counting"):
        leg_h, body_h = 18, 28
    elif pose in ("sitting", "sitting_cliff"):
        leg_h, body_h = 12, 35
    elif pose == "falling":
        leg_h, body_h = 30, 30
    else:
        leg_h, body_h = 38, 38

    hip = (x, y - leg_h)
    shoulder = (x, y - leg_h - body_h)
    head_c = (x + 2 * f, shoulder[1] - hr)

    # --- Posisi kaki ---
    lk = rk = None  # knee (hanya untuk squatting)
    poses_feet = {
        "standing":      ((x - 12 * f, y), (x + 8 * f, y)),
        "hands_pocket":  ((x - 12 * f, y), (x + 8 * f, y)),
        "squatting":     ((x - 18 * f, y), (x + 8 * f, y)),
        "running":       ((x - 22 * f, y), (x + 18 * f, y - 12)),
        "victory":       ((x - 14 * f, y), (x + 14 * f, y)),
        "sitting":       ((x + 15 * f, y + 5), (x + 22 * f, y + 8)),
        "sitting_cliff": ((x + 5 * f, y + 22), (x + 18 * f, y + 22)),
        "helping":       ((x - 10 * f, y), (x + 12 * f, y)),
        "scared":        ((x - 5 * f, y), (x + 15 * f, y)),
        "waiter":        ((x - 10 * f, y), (x + 10 * f, y)),
        "pushing":       ((x - 18 * f, y), (x + 10 * f, y)),
        "counting":      ((x - 10 * f, y), (x + 10 * f, y)),
        "photo":         ((x - 10 * f, y), (x + 10 * f, y)),
        "falling":       ((x - 20 * f, y - 8), (x + 15 * f, y + 5)),
        "chasing":       ((x - 25 * f, y), (x + 20 * f, y - 15)),
    }
    lf, rf = poses_feet.get(pose, ((x - 10, y), (x + 10, y)))
    if pose == "squatting":
        lk = (x - 22 * f, y - 20)
        rk = (x + 12 * f, y - 20)

    # --- Gambar kaki ---
    if pose == "squatting" and lk and rk:
        pygame.draw.line(surf, CARGO, hip, lk, sw + 3)
        pygame.draw.line(surf, BLACK, lk, lf, sw)
        pygame.draw.line(surf, CARGO, hip, rk, sw + 3)
        pygame.draw.line(surf, BLACK, rk, rf, sw)
    else:
        for foot in [lf, rf]:
            mid = ((hip[0] + foot[0]) // 2, (hip[1] + foot[1]) // 2)
            pygame.draw.line(surf, BLACK, hip, foot, sw)
            pygame.draw.line(surf, CARGO, hip, mid, sw + 3)
    # Sepatu
    for foot in [lf, rf]:
        pygame.draw.circle(surf, (50, 50, 50), (int(foot[0]), int(foot[1])), 5)

    # --- Badan (kaos hitam) ---
    pygame.draw.line(surf, BLACK, shoulder, hip, sw + 5)
    pygame.draw.line(surf, (30, 30, 30), shoulder, hip, sw + 3)

    # --- Posisi tangan ---
    ls = (x - 4 * f, shoulder[1] + 8)
    rs = (x + 4 * f, shoulder[1] + 8)
    poses_hands = {
        "standing":      ((x - 22 * f, shoulder[1] + 32), (x + 22 * f, shoulder[1] + 32)),
        "hands_pocket":  ((x - 10 * f, hip[1] - 2), (x + 10 * f, hip[1] - 2)),
        "squatting":     ((x - 15 * f, hip[1] + 8), (x + 15 * f, hip[1] + 8)),
        "running":       ((x + 18 * f, shoulder[1] - 5), (x - 12 * f, shoulder[1] + 18)),
        "victory":       ((x - 28 * f, shoulder[1] - 28), (x + 28 * f, shoulder[1] - 28)),
        "sitting":       ((x - 12 * f, shoulder[1] + 22), (x + 18 * f, shoulder[1] + 25)),
        "sitting_cliff": ((x - 12 * f, shoulder[1] + 28), (x + 10 * f, shoulder[1] + 22)),
        "helping":       ((x + 28 * f, shoulder[1] + 12), (x + 32 * f, shoulder[1] + 8)),
        "scared":        ((x - 28 * f, shoulder[1] - 12), (x + 28 * f, shoulder[1] - 12)),
        "waiter":        ((x - 18 * f, shoulder[1] + 22), (x + 28 * f, shoulder[1] - 8)),
        "pushing":       ((x + 35 * f, shoulder[1] + 18), (x + 35 * f, shoulder[1] + 12)),
        "counting":      ((x + 8 * f, shoulder[1] + 28), (x + 18 * f, shoulder[1] + 28)),
        "photo":         ((x + 18 * f, shoulder[1] + 12), (x + 22 * f, shoulder[1] + 8)),
        "falling":       ((x - 18 * f, shoulder[1] - 18), (x + 28 * f, shoulder[1] + 8)),
        "chasing":       ((x + 22 * f, shoulder[1] - 8), (x - 15 * f, shoulder[1] + 20)),
    }
    lh, rh = poses_hands.get(pose, ((x - 20 * f, shoulder[1] + 30), (x + 20 * f, shoulder[1] + 30)))

    # Gambar lengan
    pygame.draw.line(surf, BLACK, ls, lh, sw)
    pygame.draw.line(surf, BLACK, rs, rh, sw)
    pygame.draw.circle(surf, SKIN, (int(lh[0]), int(lh[1])), 4)
    pygame.draw.circle(surf, SKIN, (int(rh[0]), int(rh[1])), 4)

    # --- Kepala ---
    hx, hy = int(head_c[0]), int(head_c[1])
    pygame.draw.circle(surf, SKIN, (hx, hy), hr)
    pygame.draw.circle(surf, BLACK, (hx, hy), hr, 2)

    # Rambut ikal (Cunam)
    hair = [(-14, -8), (-9, -14), (-3, -16), (3, -16), (9, -14), (14, -8),
            (-11, -12), (-5, -15), (5, -15), (11, -12), (0, -17)]
    for dx, dy in hair:
        pygame.draw.circle(surf, BLACK, (hx + dx, hy + dy), 5)

    # Mata
    ex1, ex2, ey = hx - 7 * f, hx + 7 * f, hy - 2
    if eyes == "normal":
        pygame.draw.circle(surf, BLACK, (ex1, ey), 3)
        pygame.draw.circle(surf, BLACK, (ex2, ey), 3)
    elif eyes == "wide":
        for ex in [ex1, ex2]:
            pygame.draw.circle(surf, WHITE, (ex, ey), 5)
            pygame.draw.circle(surf, BLACK, (ex, ey), 5, 2)
            pygame.draw.circle(surf, BLACK, (ex, ey), 2)
    elif eyes == "closed":
        pygame.draw.line(surf, BLACK, (ex1 - 3, ey), (ex1 + 3, ey), 2)
        pygame.draw.line(surf, BLACK, (ex2 - 3, ey), (ex2 + 3, ey), 2)
    elif eyes == "sparkle":
        for ex in [ex1, ex2]:
            pygame.draw.circle(surf, BLACK, (ex, ey), 4)
            pygame.draw.circle(surf, WHITE, (ex - 1, ey - 1), 1)

    # Mulut
    my = hy + 8
    mouths = {
        "flat": lambda: pygame.draw.line(surf, BLACK, (hx - 5, my), (hx + 5, my), 2),
        "smile": lambda: pygame.draw.arc(surf, BLACK, (hx - 6, my - 4, 12, 10), 3.14, 6.28, 2),
        "big_smile": lambda: pygame.draw.arc(surf, BLACK, (hx - 8, my - 5, 16, 12), 3.14, 6.28, 2),
        "surprise": lambda: pygame.draw.circle(surf, BLACK, (hx, my + 2), 5, 2),
        "panic": lambda: pygame.draw.ellipse(surf, BLACK, (hx - 6, my - 2, 12, 10), 2),
        "talking": lambda: pygame.draw.ellipse(surf, BLACK, (hx - 5, my, 10, 6)),
        "frown": lambda: pygame.draw.arc(surf, BLACK, (hx - 6, my + 2, 12, 10), 0, 3.14, 2),
    }
    mouths.get(mouth, mouths["flat"])()

    # Aksesoris berdasarkan pose
    if pose == "waiter":
        tx, ty = int(rh[0]), int(rh[1]) - 5
        pygame.draw.rect(surf, GRAY, (tx - 15, ty - 3, 30, 4))
        pygame.draw.circle(surf, BROWN, (tx - 5, ty - 8), 5)
        pygame.draw.circle(surf, BROWN, (tx + 5, ty - 8), 5)
    elif pose == "photo":
        px, py = int(rh[0]), int(rh[1])
        pygame.draw.rect(surf, DGRAY, (px - 5, py - 8, 10, 16))
        pygame.draw.rect(surf, LBLUE, (px - 4, py - 6, 8, 12))
    elif pose == "victory":
        for hnd in [lh, rh]:
            hx2, hy2 = int(hnd[0]), int(hnd[1])
            pygame.draw.line(surf, SKIN, (hx2 - 3, hy2 - 8), (hx2, hy2), 2)
            pygame.draw.line(surf, SKIN, (hx2 + 3, hy2 - 8), (hx2, hy2), 2)


def draw_rara(surf, x, y, pose="standing", facing=1, mouth="smile", frame=0):
