def wrap(text, font, mw):
    words = text.split(' ')
    lines, c = [], ""
    for w in words:
        t = (c + " " + w) if c else w
        if font.size(t)[0] <= mw:
            c = t
        else:
            if c:
                lines.append(c)
            c = w
    if c:
        lines.append(c)
    return lines


def lc(c1, c2, t):
    """Lerp warna."""
    return tuple(int(c1[i] + (c2[i] - c1[i]) * max(0, min(1, t))) for i in range(3))


def grad_v(surf, rect, c1, c2):
    """Gradient vertikal."""
    x, y, w, h = rect
    for r in range(h):
        t = r / max(h - 1, 1)
        pygame.draw.line(surf, lc(c1, c2, t), (x, y + r), (x + w, y + r))


