# ════════════════════════════════════════════════════════════════
#  MAIN LOOP
# ════════════════════════════════════════════════════════════════
def main():
    current = 0
    total = len(BEATS)
    frame = 0
    running = True

    while running:
        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                running = False
            elif ev.type == pygame.KEYDOWN:
                if ev.key == pygame.K_ESCAPE:
                    running = False
                elif ev.key in (pygame.K_RIGHT, pygame.K_SPACE, pygame.K_RETURN):
                    current = min(current + 1, total - 1)
                elif ev.key == pygame.K_LEFT:
                    current = max(current - 1, 0)

        beat = BEATS[current]

        # --- Background ---
        bg_name = beat.get("bg", "black")
        if bg_name == "forest":
            bg_forest(screen, frame)
        elif bg_name == "room":
            bg_room(screen)
        elif bg_name == "room_night":
            bg_room_night(screen)
        elif bg_name == "warkop":
            bg_warkop(screen)
        elif bg_name == "road":
            bg_road(screen)
        elif bg_name == "minimarket":
            bg_minimarket(screen)
        elif bg_name == "sunset_cliff":
            bg_sunset_cliff(screen, frame)
        else:
            bg_black(screen)

        # --- Scene header ---
        if beat.get("scene"):
            ui_scene_hdr(screen, beat["scene"][0], beat["scene"][1])

        # --- Custom draw (characters, effects, dialogue) ---
        if beat.get("draw"):
            beat["draw"](screen, frame)

        # --- Controls UI ---
        ui_controls(screen, current, total)

        pygame.display.flip()
        clock.tick(FPS)
        frame += 1

    pygame.quit()
    sys.exit()


if __name__ == "__main__":
    main()
