    pygame.draw.ellipse(surf, (40, 30, 20), (hx + hr - 7, hy - 5, 12, 45))
    pygame.draw.ellipse(surf, (40, 30, 20), (hx - hr + 2, hy - hr - 5, hr * 2 - 4, 20))
    pygame.draw.arc(surf, (40, 30, 20), (hx - 12, hy - hr - 3, 24, 15), 3.14, 6.28, 4)

    # Mata
    ex1, ex2, ey = hx - 6 * f, hx + 6 * f, hy - 2
    for ex in [ex1, ex2]:
        pygame.draw.circle(surf, BLACK, (ex, ey), 3)
        pygame.draw.circle(surf, WHITE, (ex - 1, ey - 1), 1)
    # Blush
    pygame.draw.circle(surf, (255, 180, 180), (ex1 - 5, ey + 8), 5)
    pygame.draw.circle(surf, (255, 180, 180), (ex2 + 5, ey + 8), 5)

    # Mulut
    my2 = hy + 8
    if mouth == "smile":
        pygame.draw.arc(surf, BLACK, (hx - 5, my2 - 3, 10, 8), 3.14, 6.28, 2)
    elif mouth == "big_smile":
        pygame.draw.arc(surf, BLACK, (hx - 7, my2 - 4, 14, 10), 3.14, 6.28, 2)
    elif mouth == "confused":
